# ── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_HOST=mqtts://xxx.amazonaws.com:8883
# mqtts = MQTT over SSL, tcp = MQTT non SSL
MQTTS_ON=false
MQTT_TOPIC=$TOPIC
MQTT_CA_CERTIFICATE=certs/$AmazonRootCA1.pem
MQTT_CLIENT_CERTIFICATE=certs/$certificate.pem.crt
MQTT_PRIVATE_KEY=certs/$private.pem.key

# ── Main PLC (Mitsubishi) ─────────────────────────────────────────────────────
MAIN_PLC_BRAND=mitsubishi
PLC_HOST=$HOST_IP_ADDRESS
PLC_PORT=5012
PLC_MODEL=false                          # true = FX series, false = iQ-R/Q series
DEVICES_16bit=D,0,1,D,1,1,D,2,1,D,3,1
DEVICES_32bit=D,650,2,D,676,2
DEVICES_2bit=M,24,3,M,25,3
DEVICES_ASCII=
# WRITE_MAP_SEC_TO_PRIM: copy a register from the secondary PLC into the main PLC.
# Format (repeatable, pipe-separated):
#   SEC_DEVICE,MAIN_DEVICE
#   └─ read this    └─ write result here
#
# Example below reads D100 from the Shibaura and writes it into D200 on the Mitsubishi:
#   WRITE_MAP_SEC_TO_PRIM=D,100|D,200
#
# Multiple mappings — separate each pair with a semicolon:
#   WRITE_MAP_SEC_TO_PRIM=D,100|D,200;D,101|D,201;M,10|M,50
#
WRITE_MAP_SEC_TO_PRIM=

# WRITE_MAP_SEC_TO_PRIM_CONDITION: only perform the write when a register
# on either PLC matches a given value. Useful for interlocks — e.g. only
# sync production data when the machine is actually running.
#
# Format (repeatable, pipe-separated):
#   DEVICE,ADDRESS==VALUE   → write only when register equals value
#   DEVICE,ADDRESS!=VALUE   → write only when register does not equal value
#
# The device is looked up from the already-read deviceValues cache so
# no extra PLC read is needed at write time.
#
# Examples:
#   M,64==1               → only write when M64 on main PLC = 1 (machine running)
#   M,64==1;M,30!=0       → M64 must be 1 AND M30 must not be 0
#   D,71==100;M,25!=1     → D71 equals 100 AND M25 is not 1
#
WRITE_MAP_SEC_TO_PRIM_CONDITION=

# ── Secondary PLC (Shibaura) ──────────────────────────────────────────────────
SUB_PLC_BRAND=shibaura
SEC_PLC_HOST=$SEC_HOST_IP_ADDRESS
SEC_PLC_PORT=502                         # Shibaura: try 502 (Modbus) first
SEC_DEVICES_16bit=D,0,1,D,1,1
SEC_DEVICES_32bit=
SEC_DEVICES_2bit=
SEC_DEVICES_ASCII=

# WRITE_MAP_PRIM_TO_SEC: the reverse direction — copy a register from the
# main PLC into the secondary PLC.
# Same format as WRITE_MAP_SEC_TO_PRIM.
#
# Example reads D200 from the Mitsubishi and writes it into D100 on the Shibaura:
#   WRITE_MAP_PRIM_TO_SEC=D,200|D,100
#
WRITE_MAP_PRIM_TO_SEC=

# WRITE_MAP_PRIM_TO_SEC_CONDITION: same logic as SEC_TO_PRIM_CONDITION
# but guards the prim→sec direction.
#
# Example — only sync when main PLC M64 is 1 and secondary M30 is not 0:
#   WRITE_MAP_PRIM_TO_SEC_CONDITION=M,64==1;M,30!=0
#
WRITE_MAP_PRIM_TO_SEC_CONDITION=